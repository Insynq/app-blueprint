# .env.example — copy to .env and fill in values
# This file is committed. .env is gitignored.
#
# Add your project's required environment variables here during kickoff.
# Follow the naming convention established in your project:
#   - VITE_  prefix for client-side variables (Vite projects)
#   - NEXT_PUBLIC_  prefix for client-side variables (Next.js projects)
#   - No prefix for server-only variables
#
# Example entries (replace with your actual variables):

# Database
# DATABASE_URL=postgresql://user:password@localhost:5432/mydb

# Auth
# AUTH_SECRET=your-secret-here

# External APIs
# STRIPE_SECRET_KEY=sk_test_...
# RESEND_API_KEY=re_...
